# i2AIMS Email Notification Configuration
# Copy this file to .env and fill in your actual credentials

# ── SMTP Server Configuration ──────────────────────────────────
# For Gmail: smtp.gmail.com (port 587)
# For Outlook: smtp.office365.com (port 587)
# For custom SMTP: your-smtp-server.com

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# ── Email Credentials ───────────────────────────────────────────
# For Gmail: Use App Password (not your regular password)
#   1. Enable 2FA: https://myaccount.google.com/security
#   2. Generate App Password: https://myaccount.google.com/apppasswords
#   3. Use the generated 16-character password below

SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here

# ── Alert Configuration ─────────────────────────────────────────
# From address (usually same as SMTP_USERNAME)
ALERT_FROM=your-email@gmail.com

# To addresses (comma-separated for multiple recipients)
ALERT_TO=engineer1@company.com,engineer2@company.com,manager@company.com

# ── LLM Configuration (for RCA) ─────────────────────────────────
# Get free API key at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
